<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>VFDA Tech Stack Setup</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f4f0;min-height:100vh;display:flex;align-items:flex-start;justify-content:center;padding:20px}
#app{width:100%;max-width:900px;border:1px solid #e0dfd8;border-radius:14px;overflow:hidden;background:#f5f4f0;box-shadow:0 2px 20px rgba(0,0,0,0.08);display:flex;flex-direction:column;height:640px}
#header{display:flex;align-items:center;gap:12px;padding:13px 20px;background:#fff;border-bottom:1px solid #e8e7e0;flex-shrink:0}
.header-text{flex:1}
.header-text .ht{font-size:14px;font-weight:600;color:#1a1a18}
.header-text .hs{font-size:11px;color:#888;margin-top:1px}
#progress-wrap{display:flex;align-items:center;gap:8px}
#prog-label{font-size:12px;color:#888;white-space:nowrap}
#prog-bar-bg{width:110px;height:5px;background:#e0dfd8;border-radius:3px;overflow:hidden}
#prog-bar{height:100%;width:0%;background:#3b82f6;border-radius:3px;transition:width 0.5s ease}
#prog-pct{font-size:12px;font-weight:500;color:#888;min-width:28px;text-align:right}
#body{display:flex;flex:1;overflow:hidden}
#sidebar{width:230px;flex-shrink:0;border-right:1px solid #e8e7e0;background:#fff;overflow-y:auto;padding:10px 8px}
.item{display:flex;align-items:flex-start;gap:8px;padding:7px 8px;border-radius:8px;margin-bottom:2px;transition:background 0.4s}
.item.done{background:rgba(34,197,94,0.09)}
.item-dot{width:18px;height:18px;border-radius:50%;flex-shrink:0;margin-top:1px;border:1.5px solid #ccc;display:flex;align-items:center;justify-content:center;transition:all 0.3s}
.item-dot.done{background:#22c55e;border:none}
.item-lbl{font-size:12px;font-weight:500;color:#1a1a18;line-height:1.3}
.item-lbl.done{color:#16a34a;text-decoration:line-through;font-weight:400}
.item-dsc{font-size:10px;color:#999;margin-top:2px;line-height:1.3}
#advance-wrap{margin:10px 4px 4px;padding:12px;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.28);border-radius:10px;text-align:center;display:none}
.adv-t{font-size:12px;font-weight:600;color:#16a34a;margin-bottom:8px}
#advance-btn{width:100%;padding:8px 0;background:#22c55e;color:#fff;border:none;border-radius:7px;font-size:12px;font-weight:600;cursor:pointer}
#chat-panel{flex:1;display:flex;flex-direction:column;overflow:hidden}
#welcome{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;gap:14px;text-align:center}
.wico{width:52px;height:52px;border-radius:50%;background:#eff6ff;display:flex;align-items:center;justify-content:center}
.wt{font-size:16px;font-weight:600;color:#1a1a18}
.ws{font-size:13px;color:#666;max-width:300px;line-height:1.6}
#start-btn{margin-top:4px;padding:10px 26px;background:#1a1a18;color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:500;cursor:pointer}
#start-btn:hover{background:#333}
#messages{flex:1;overflow-y:auto;padding:16px 20px;display:none;flex-direction:column;gap:10px}
.bw-user{display:flex;justify-content:flex-end}
.bw-ai{display:flex;justify-content:flex-start}
.bubble{max-width:80%;padding:9px 14px;font-size:13px;line-height:1.65}
.bubble.user{border-radius:14px 14px 4px 14px;background:#1a1a18;color:#fff}
.bubble.ai{border-radius:14px 14px 14px 4px;background:#fff;color:#1a1a18;border:1px solid #e8e7e0}
#typing-row{display:none;padding:0 20px 10px;justify-content:flex-start}
#typing-row .bubble{padding:10px 14px}
.dots{display:flex;gap:4px;align-items:center}
.dot{width:5px;height:5px;border-radius:50%;background:#aaa}
@keyframes bounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
#d1{animation:bounce 0.9s ease-in-out 0s infinite}
#d2{animation:bounce 0.9s ease-in-out 0.15s infinite}
#d3{animation:bounce 0.9s ease-in-out 0.3s infinite}
#input-area{padding:12px 16px;border-top:1px solid #e8e7e0;background:#fff;display:none;gap:8px;align-items:flex-end;flex-shrink:0}
#msg-input{flex:1;resize:none;padding:9px 13px;border-radius:10px;border:1px solid #ddd;background:#f9f8f5;color:#1a1a18;font-size:13px;font-family:inherit;line-height:1.5;min-height:38px;max-height:90px;outline:none}
#msg-input:focus{border-color:#aaa}
#send-btn{padding:9px 16px;background:#1a1a18;color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:500;cursor:pointer;flex-shrink:0}
#send-btn:disabled{background:#ccc;cursor:default}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:#ddd;border-radius:2px}
</style>
</head>
<body>
<div id="app">
  <div id="header">
    <div class="header-text">
      <div class="ht">Tech Stack Setup</div>
      <div class="hs">Complete all 10 items before hiring your VA</div>
    </div>
    <div id="progress-wrap">
      <div id="prog-label">0 / 10</div>
      <div id="prog-bar-bg"><div id="prog-bar"></div></div>
      <div id="prog-pct">0%</div>
    </div>
  </div>
  <div id="body">
    <div id="sidebar">
      <div id="item-list"></div>
      <div id="advance-wrap">
        <div class="adv-t">All done!</div>
        <button id="advance-btn">Advance to Stage 2 →</button>
      </div>
    </div>
    <div id="chat-panel">
      <div id="welcome">
        <div class="wico">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
        </div>
        <div class="wt">Ready to build your tech stack?</div>
        <div class="ws">Your AI coach will walk you through all 10 items, verify each one, and check them off as you go.</div>
        <button id="start-btn">Let's go</button>
      </div>
      <div id="messages"></div>
      <div id="typing-row">
        <div class="bubble ai">
          <div class="dots">
            <div class="dot" id="d1"></div>
            <div class="dot" id="d2"></div>
            <div class="dot" id="d3"></div>
          </div>
        </div>
      </div>
      <div id="input-area">
        <textarea id="msg-input" placeholder="Tell me what you have set up, or ask for help..." rows="1"></textarea>
        <button id="send-btn">Send</button>
      </div>
    </div>
  </div>
</div>

<script>
var ITEMS = [
  {id:"ehr",             label:"EHR and training",          desc:"System set up + VA training plan ready"},
  {id:"voip",            label:"VOIP and training",         desc:"Phone system configured + training ready"},
  {id:"slack",           label:"Slack setup and channels",  desc:"Workspace, channels, VA invite ready"},
  {id:"trello",          label:"Trello board access",       desc:"Board live, VA has access"},
  {id:"patient_journey", label:"Perfect patient journey",   desc:"Patient flow mapped and documented"},
  {id:"reexam",          label:"Re-exam checklist",         desc:"Checklist built and finalized"},
  {id:"screenconnect",   label:"ScreenConnect",             desc:"Remote access installed and tested"},
  {id:"onepassword",     label:"1Password",                 desc:"Vaults set up, VA access ready"},
  {id:"texting",         label:"Texting platform",          desc:"SMS platform configured for VA"},
  {id:"va_computer",     label:"Dedicated VA computer",     desc:"Sourced, set up, and ready"}
];

var SYSTEM = "You are a concise, direct tech stack setup coach for chiropractors preparing to hire a Virtual Front Desk Assistant (VA). You only know about this one task: getting their tech stack ready.\n\nThe 10 required items:\n- ehr: EHR system set up AND training plan ready for VA\n- voip: VOIP phone system configured AND training plan ready\n- slack: Slack workspace created, channels built, VA invite ready\n- trello: Trello board set up, VA has access\n- patient_journey: Perfect patient journey documented\n- reexam: Re-exam checklist created and finalized\n- screenconnect: ScreenConnect remote access installed and tested\n- onepassword: 1Password set up, correct vaults, VA access ready\n- texting: Texting/SMS platform configured for VA use\n- va_computer: Dedicated VA computer sourced, set up, ready\n\nRules:\n- Be warm but efficient. Doctors are busy.\n- When they say they have done something, ask ONE short verification question before marking complete.\n- Once they confirm, mark it done.\n- Let them work in any order. Give brief help if stuck.\n- Greet them warmly and ask what they have already set up or where to begin.\n\nCRITICAL: Respond ONLY in raw valid JSON. No markdown, no code blocks, no extra text. Use exactly:\n{\"message\":\"your response\",\"markComplete\":[\"id1\",\"id2\"]}\nmarkComplete = IDs just confirmed complete. Empty array if none.";

var state = { checklist: {}, history: [], loading: false };
ITEMS.forEach(function(i){ state.checklist[i.id] = false; });

function el(id){ return document.getElementById(id); }

function renderList() {
  var done = 0;
  ITEMS.forEach(function(i){ if(state.checklist[i.id]) done++; });
  var pct = Math.round(done / ITEMS.length * 100);
  el("prog-label").textContent = done + " / " + ITEMS.length;
  el("prog-bar").style.width = pct + "%";
  el("prog-bar").style.background = done === ITEMS.length ? "#22c55e" : "#3b82f6";
  el("prog-pct").textContent = pct + "%";
  el("prog-pct").style.color = done === ITEMS.length ? "#16a34a" : "#888";
  var list = el("item-list");
  list.innerHTML = "";
  ITEMS.forEach(function(item) {
    var d = state.checklist[item.id];
    var div = document.createElement("div");
    div.className = "item" + (d ? " done" : "");
    div.innerHTML =
      '<div class="item-dot' + (d ? " done" : "") + '">' +
      (d ? '<svg width="10" height="10" viewBox="0 0 12 12"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>' : "") +
      '</div><div>' +
      '<div class="item-lbl' + (d ? " done" : "") + '">' + item.label + '</div>' +
      '<div class="item-dsc">' + item.desc + '</div>' +
      '</div>';
    list.appendChild(div);
  });
  el("advance-wrap").style.display = done === ITEMS.length ? "block" : "none";
}

function addMsg(role, text) {
  var msgs = el("messages");
  var w = document.createElement("div");
  w.className = role === "user" ? "bw-user" : "bw-ai";
  var b = document.createElement("div");
  b.className = "bubble " + (role === "user" ? "user" : "ai");
  b.textContent = text;
  w.appendChild(b);
  msgs.appendChild(w);
  msgs.scrollTop = msgs.scrollHeight;
}

function setLoading(on) {
  state.loading = on;
  el("typing-row").style.display = on ? "flex" : "none";
  el("send-btn").disabled = on;
  if(on) el("messages").scrollTop = 99999;
}

async function callAPI(msgs) {
  var res = await fetch("/api/chat", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ system: SYSTEM, messages: msgs })
  });
  var data = await res.json();
  if(data.error) throw new Error(data.error.message || data.error);
  var block = (data.content || []).find(function(b){ return b.type === "text"; });
  var raw = block ? block.text : "";
  if(!raw) raw = '{"message":"Let me help you get started. What have you already set up?","markComplete":[]}';
  try { return JSON.parse(raw.replace(/```json|```/g,"").trim()); }
  catch(e) { return { message: raw, markComplete: [] }; }
}

el("start-btn").onclick = async function() {
  el("welcome").style.display = "none";
  el("messages").style.display = "flex";
  el("typing-row").style.display = "flex";
  el("input-area").style.display = "flex";
  setLoading(true);
  var seed = { role: "user", content: "Hi, I am a doctor and I am ready to work through my tech stack setup." };
  state.history.push(seed);
  try {
    var p = await callAPI(state.history);
    state.history.push({ role: "assistant", content: p.message });
    addMsg("assistant", p.message);
  } catch(e) {
    addMsg("assistant", "Error: " + e.message);
  }
  setLoading(false);
  el("msg-input").focus();
};

async function sendMsg() {
  var inp = el("msg-input");
  var txt = inp.value.trim();
  if(!txt || state.loading) return;
  inp.value = ""; inp.style.height = "auto";
  state.history.push({ role: "user", content: txt });
  addMsg("user", txt);
  setLoading(true);
  try {
    var p = await callAPI(state.history);
    if(p.markComplete && p.markComplete.length) {
      p.markComplete.forEach(function(id){ if(id in state.checklist) state.checklist[id] = true; });
      renderList();
    }
    state.history.push({ role: "assistant", content: p.message });
    addMsg("assistant", p.message);
  } catch(e) {
    addMsg("assistant", "Error: " + e.message);
  }
  setLoading(false);
  el("msg-input").focus();
}

el("send-btn").onclick = sendMsg;
el("msg-input").onkeydown = function(e) {
  if(e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMsg(); }
};
el("msg-input").oninput = function() {
  this.style.height = "auto";
  this.style.height = Math.min(this.scrollHeight, 90) + "px";
};
el("advance-btn").onclick = function() {
  alert("Stage 1 complete! Add your GHL webhook URL to api/chat.js to auto-unlock Stage 2.");
};

renderList();
</script>
</body>
</html>
